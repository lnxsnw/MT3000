#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034
# shellcheck disable=SC3043
USE_PROCD=1

START=99

. /lib/functions/gl_util.sh
model=$(get_model)

AGH_RAM_DIR="/tmp/AGH_data"
AGH_UPDATE_DIR="/tmp/AGH_update"
AGH_PERSIST_DIR="/etc/AdGuardHome"
AGH_CONFIG="$AGH_PERSIST_DIR/config.yaml"
AGH_RELEASE_TAR="AdGuardHome_linux_arm64.tar.gz"
AGH_CHECKSUM_FILE="checksums.txt"
AGH_DOWNLOAD_URL="https://github.com/AdguardTeam/AdGuardHome/releases/latest/download/$AGH_RELEASE_TAR"
AGH_CHECKSUM_URL="https://github.com/AdguardTeam/AdGuardHome/releases/latest/download/$AGH_CHECKSUM_FILE"
AGH_RAM_BIN="$AGH_RAM_DIR/AdGuardHome"
OFFLINE_BLOCKLIST_SOURCE="https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/adblock/pro.plus.mini.txt"
OFFLINE_BLOCKLIST_DEST="/etc/AdGuardHome/offline-blocklist.txt"
# Do check /tmp/AGH_update_check.sh if you intend to change the defaults this script has set.

start_service() {
    [ "$(uci -q get adguardhome.config.enabled)" = "1" ] || exit 0

    mkdir -p "$AGH_PERSIST_DIR"

    # -----------------------------------------------------------------------
    # Step 1: First-time download — tar not present locally.
    #         Download tar + checksum into /tmp/AGH_update, verify, then move
    #         the tar to AGH_PERSIST_DIR. Falls through to start after this.
    # -----------------------------------------------------------------------
    if [ ! -f "$AGH_PERSIST_DIR/$AGH_RELEASE_TAR" ]; then
        mkdir -p "$AGH_UPDATE_DIR"

        wget -q "$AGH_DOWNLOAD_URL" -O "$AGH_UPDATE_DIR/$AGH_RELEASE_TAR" || {
            rm -rf "$AGH_UPDATE_DIR"
            exit 1
        }
        wget -q "$AGH_CHECKSUM_URL" -O "$AGH_UPDATE_DIR/$AGH_CHECKSUM_FILE" || {
            rm -rf "$AGH_UPDATE_DIR"
            exit 1
        }

        CHECK_LINE=$(grep "[[:space:]]\./$AGH_RELEASE_TAR\$" "$AGH_UPDATE_DIR/$AGH_CHECKSUM_FILE")
        echo "$CHECK_LINE" | sed "s|\./$AGH_RELEASE_TAR|$AGH_UPDATE_DIR/$AGH_RELEASE_TAR|" \
            | sha256sum -c - >/dev/null 2>&1 || {
            rm -rf "$AGH_UPDATE_DIR"
            exit 1
        }

        mv "$AGH_UPDATE_DIR/$AGH_RELEASE_TAR" "$AGH_PERSIST_DIR/$AGH_RELEASE_TAR"
        rm -rf "$AGH_UPDATE_DIR"

        # Download offline blocklist on first run
        mkdir -p "$(dirname "$OFFLINE_BLOCKLIST_DEST")"
        wget -q "$OFFLINE_BLOCKLIST_SOURCE" -O "$OFFLINE_BLOCKLIST_DEST"
    fi

    # -----------------------------------------------------------------------
    # Step 2: Tar is present — extract and start AdGuardHome.
    # -----------------------------------------------------------------------
    
    # Update the offline blocklist first if an update is present
    NEW="/etc/AdGuardHome/offline-blocklist.txt.new"
    DEST="/etc/AdGuardHome/offline-blocklist.txt"

    [ -f "$NEW" ] && mv -f "$NEW" "$DEST"

    # Begin the extraction and execution of the AdGuardHome app
    mkdir -p "$AGH_RAM_DIR"
    tar -xzf "$AGH_PERSIST_DIR/$AGH_RELEASE_TAR" -C "$AGH_RAM_DIR"
    cp /tmp/AGH_data/AdGuardHome/AdGuardHome /tmp/AGH_data/AGH
    rm -rf /tmp/AGH_data/AdGuardHome
    mv /tmp/AGH_data/AGH /tmp/AGH_data/AdGuardHome
    chmod +x "$AGH_RAM_BIN"

    /etc/init.d/firewall reload

    procd_open_instance
    procd_set_param env GOMEMLIMIT=100MiB GOGC=40 GOMAXPROCS=1 # See: https://github.com/AdguardTeam/AdGuardHome/issues/5606#issuecomment-2222746679
    procd_set_param respawn
    procd_set_param group explict_vpn
    procd_set_param stderr 1
    procd_set_param command "$AGH_RAM_BIN" --glinet --no-check-update -c "$AGH_CONFIG" -w "$AGH_RAM_DIR" -l syslog
    procd_close_instance

    # -----------------------------------------------------------------------
    # Step 3: Inject async update checker — runs in the background without
    #         blocking the service start. /tmp/AGH_update is always cleaned up
    #         on exit regardless of the code path taken.
    # -----------------------------------------------------------------------
    cat > /tmp/AGH_update_check.sh << 'UPDATESCRIPT'
#!/bin/sh
AGH_PERSIST_DIR="/etc/AdGuardHome"
AGH_UPDATE_DIR="/tmp/AGH_update"
AGH_RELEASE_TAR="AdGuardHome_linux_arm64.tar.gz"
AGH_CHECKSUM_FILE="checksums.txt"
AGH_DOWNLOAD_URL="https://github.com/AdguardTeam/AdGuardHome/releases/latest/download/$AGH_RELEASE_TAR"
AGH_CHECKSUM_URL="https://github.com/AdguardTeam/AdGuardHome/releases/latest/download/$AGH_CHECKSUM_FILE"
OFFLINE_BLOCKLIST_SOURCE="https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/adblock/pro.plus.mini.txt"
OFFLINE_BLOCKLIST_DEST="/etc/AdGuardHome/offline-blocklist.txt.new"
OFFLINE_BLOCKLIST_MAX_AGE_DAYS=28

# Always clean up the staging dir on exit
trap 'rm -rf "$AGH_UPDATE_DIR"' EXIT

# Helper: download with up to 3 attempts, exits script on total failure
wget_retry() {
    _url="$1"
    _dest="$2"
    _attempts=0
    while [ "$_attempts" -lt 3 ]; do
        wget -q "$_url" -O "$_dest" && return 0
        _attempts=$((_attempts + 1))
        rm -f "$_dest"
    done
    return 1
}

# No internet — nothing to do, exit cleanly
ping -c1 github.com >/dev/null 2>&1 || exit 0

mkdir -p "$AGH_UPDATE_DIR"

# Fetch remote checksum (retry 3x); give up entirely on failure
wget_retry "$AGH_CHECKSUM_URL" "$AGH_UPDATE_DIR/$AGH_CHECKSUM_FILE" || exit 1

REMOTE_CHECK_LINE=$(grep "[[:space:]]\./$AGH_RELEASE_TAR\$" "$AGH_UPDATE_DIR/$AGH_CHECKSUM_FILE")

# Compare remote checksum against the locally stored tar — exit if already up to date
LOCAL_CHECK=$(echo "$REMOTE_CHECK_LINE" | sed "s|\./$AGH_RELEASE_TAR|$AGH_PERSIST_DIR/$AGH_RELEASE_TAR|")
echo "$LOCAL_CHECK" | sha256sum -c - >/dev/null 2>&1 && exit 0

# Checksums differ — download new release into staging dir (retry 3x)
wget_retry "$AGH_DOWNLOAD_URL" "$AGH_UPDATE_DIR/$AGH_RELEASE_TAR" || exit 1

# Verify the freshly downloaded tar against the remote checksum
NEW_CHECK=$(echo "$REMOTE_CHECK_LINE" | sed "s|\./$AGH_RELEASE_TAR|$AGH_UPDATE_DIR/$AGH_RELEASE_TAR|")
echo "$NEW_CHECK" | sha256sum -c - >/dev/null 2>&1 || exit 1

# Atomically replace the persisted tar with the verified new one
rm -f "$AGH_PERSIST_DIR/$AGH_RELEASE_TAR"
mv "$AGH_UPDATE_DIR/$AGH_RELEASE_TAR" "$AGH_PERSIST_DIR/$AGH_RELEASE_TAR"

# Offline Blocklist
should_download=false
if [[ ! -f "$OFFLINE_BLOCKLIST_DEST" ]]; then
    should_download=true
elif [[ $(find "$OFFLINE_BLOCKLIST_DEST" -mtime +"$((OFFLINE_BLOCKLIST_MAX_AGE_DAYS - 1))" 2>/dev/null) ]]; then
    should_download=true
fi

if [[ "$should_download" == true ]]; then
    mkdir -p "$(dirname "$OFFLINE_BLOCKLIST_DEST")"
    wget -q "$OFFLINE_BLOCKLIST_SOURCE" -O "$OFFLINE_BLOCKLIST_DEST"
fi

# trap handles cleanup of AGH_UPDATE_DIR on exit
UPDATESCRIPT

    chmod +x /tmp/AGH_update_check.sh
    /tmp/AGH_update_check.sh &
}

stop_service() {
    /etc/init.d/firewall reload
}